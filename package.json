{
  "name": "capstone---foodwise",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "server/jurnal-api/jurnal-api",
    "server/log-in-api",
    "server/sign-up-api"
  ],
  "scripts": {
    "dev:client": "vite",
    "dev:server:jurnal": "nodemon server/jurnal-api/jurnal-api/server.js",
    "dev:server:login": "nodemon server/log-in-api/index.js",
    "dev:server:signup": "nodemon server/sign-up-api/server.js",
    "dev:server": "concurrently \"npm run dev:server:jurnal\" \"npm run dev:server:login\" \"npm run dev:server:signup\"",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "flowbite": "^4.0.1",
    "flowbite-react": "^0.12.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  }
}
